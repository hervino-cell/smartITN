<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Nom étudiant -->
        <TextView
            android:id="@+id/tvEtudiantNom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nom de l'étudiant"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <!-- Ligne séparatrice -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="10dp"/>

        <!-- Notes TP et Examen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Carte TP -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:background="#E8F5E9"
                android:orientation="vertical"
                android:padding="10dp"
                android:gravity="center"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRAVAUX PRATIQUES"
                    android:textColor="#388E3C"
                    android:textSize="10sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvNoteTP"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TP : --"
                    android:textColor="#1B5E20"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Carte Examen -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:background="#E3F2FD"
                android:orientation="vertical"
                android:padding="10dp"
                android:gravity="center"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EXAMEN FINAL"
                    android:textColor="#1565C0"
                    android:textSize="10sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvNoteExamen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Examen : --"
                    android:textColor="#0D47A1"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Moyenne + mention -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvMoyenne"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Moy : --"
                android:textColor="#424242"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvMention"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="6dp"
                android:background="#F5F5F5"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>